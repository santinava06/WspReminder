# Bridge URLs por sesion (cada cuenta necesita su propio bridge-server)
# Los puertos por defecto del start-bridges.ps1 son 3178-3183:
BRIDGE_URL_ADMIN=http://localhost:3178
BRIDGE_URL_COMERCIAL_1=http://localhost:3179
BRIDGE_URL_COMERCIAL_2=http://localhost:3180
BRIDGE_URL_ACADEMICO_1=http://localhost:3181
BRIDGE_URL_IN=http://localhost:3182
BRIDGE_URL_LUCIANA=http://localhost:3183

# Webhook de notificacion cuando una sesion se desconecta
# WEBHOOK_DISCONNECT_URL=https://hooks.example.com/wh

# Origenes CORS permitidos (separados por coma)
# ALLOWED_ORIGINS=https://wspreminder.vercel.app,http://localhost:5173

# Dias de retencion del historial (default: 90)
# HISTORY_TTL_DAYS=90

# Nivel de log: debug, info, warn, error (default: info en prod)
# LOG_LEVEL=info

# Puerto del servidor (default: 3177)
# PORT=3177
